{
  "name": "@urantia/api",
  "version": "0.3.0",
  "description": "Typed client for the Urantia Papers API (api.urantia.dev)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
